{
    "version": 2,
    "headers": [
        {
            "source": "/defacto-student-erp.apk",
            "headers": [
                {
                    "key": "Content-Type",
                    "value": "application/vnd.android.package-archive"
                },
                {
                    "key": "Content-Disposition",
                    "value": "attachment; filename=defacto-student-erp.apk"
                }
            ]
        },
        {
            "source": "/app-debug.apk",
            "headers": [
                {
                    "key": "Content-Type",
                    "value": "application/vnd.android.package-archive"
                },
                {
                    "key": "Content-Disposition",
                    "value": "attachment; filename=defacto-student-erp.apk"
                }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.js"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ],
    "functions": {
        "api/**/*": {
            "includeFiles": "backend/**"
        }
    }
}
